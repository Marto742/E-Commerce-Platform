# =============================================================================
# E-Commerce Platform — Environment Variable Reference
# =============================================================================
#
# This is the MASTER REFERENCE for all environment variables in the monorepo.
# Do NOT copy or use this file directly — use the per-service templates:
#
#   cp apps/api/.env.example             apps/api/.env
#   cp apps/web/.env.local.example       apps/web/.env.local
#   cp apps/admin/.env.local.example     apps/admin/.env.local
#
# Variables marked REQUIRED must be set before the service will start.
# Variables marked OPTIONAL are only needed when integrating that feature.
#
# =============================================================================


# =============================================================================
# apps/api — Express API server                       → apps/api/.env
# =============================================================================

# Server
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL) ─────────────────────────────────────────── REQUIRED
# Started via Docker Compose (Task 2.6)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_dev

# ── Cache (Redis) ──────────────────────────────────────────────────── REQUIRED
# Started via Docker Compose (Task 2.6)
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────────────── REQUIRED
# Generate secure values with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────────────── REQUIRED
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ── Stripe ─────────────────────────────────────────────────────── OPTIONAL (Phase 5)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ── Email — Resend ─────────────────────────────────────────────── OPTIONAL (Phase 8)
# https://resend.com/api-keys
RESEND_API_KEY=re_
EMAIL_FROM=noreply@yourdomain.com

# ── Object Storage — Cloudflare R2 ─────────────────────────────── OPTIONAL (Phase 9)
# https://dash.cloudflare.com → R2 Object Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ecommerce-assets
R2_PUBLIC_URL=https://cdn.yourdomain.com


# =============================================================================
# apps/web — Next.js storefront (port 3000)       → apps/web/.env.local
# =============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# Stripe publishable key — safe to expose client-side (Phase 5)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_


# =============================================================================
# apps/admin — Next.js admin dashboard (port 3001) → apps/admin/.env.local
# =============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:4000/v1


# =============================================================================
# Test environment — NO .env.test FILE NEEDED
# =============================================================================
# Test variables are hardcoded in apps/api/vitest.config.ts:
#
#   NODE_ENV=test
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_test
#   REDIS_URL=redis://localhost:6379
#   JWT_ACCESS_SECRET=test-access-secret-at-least-32-characters-long
#   JWT_REFRESH_SECRET=test-refresh-secret-at-least-32-characters-long
#
# Tests use a separate database (ecommerce_test) to avoid clobbering dev data.
# =============================================================================
