{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @repo/api db:generate"
  },
  "deploy": {
    "startCommand": "pnpm --filter @repo/api exec prisma migrate deploy && pnpm --filter @repo/api exec tsx src/index.ts",
    "healthcheckPath": "/v1/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
