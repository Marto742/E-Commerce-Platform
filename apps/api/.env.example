# Server
NODE_ENV=development
PORT=4000

# Database (set up in Task 2.6 — Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_dev

# Redis (set up in Task 2.6 — Docker)
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-hex-string-in-production
JWT_REFRESH_SECRET=change-me-to-a-different-random-64-char-hex-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated — web app + admin app)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Stripe (set up in Phase 5)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Resend email (set up in Phase 8)
RESEND_API_KEY=re_
EMAIL_FROM=noreply@yourdomain.com

# Cloudflare R2 (set up in Phase 9)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ecommerce-assets
R2_PUBLIC_URL=https://cdn.yourdomain.com
