# =============================================================================
# apps/api — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Variables are validated at startup by src/config/env.ts (Zod).
# The server will exit with a clear error if any REQUIRED variable is missing.
#
# REQUIRED  — server won't start without these
# OPTIONAL  — only needed when integrating that feature/phase
# =============================================================================

# ── Server ────────────────────────────────────────────────────────── REQUIRED
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL) ─────────────────────────────────────────── REQUIRED
# Local: native PostgreSQL.  Production: Neon (see docs/deployment.md).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_dev

# ── Cache (Redis) ──────────────────────────────────────────────────── REQUIRED
# Local: native Redis.  Production: Upstash (rediss://… URL).
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────────────── REQUIRED
# Generate secure values with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────────────────────────── REQUIRED
# Comma-separated list of allowed origins (web app + admin app)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ── Stripe ─────────────────────────────────────────────────────── OPTIONAL (Phase 5)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ── Email — Resend ─────────────────────────────────────────────── OPTIONAL (Phase 8)
# https://resend.com/api-keys
RESEND_API_KEY=re_
EMAIL_FROM=noreply@yourdomain.com

# ── Object Storage — Cloudflare R2 ─────────────────────────────── OPTIONAL (Phase 9)
# https://dash.cloudflare.com → R2 Object Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ecommerce-assets
R2_PUBLIC_URL=https://cdn.yourdomain.com

# ── Search — Meilisearch ─────────────────────────────────── OPTIONAL (defaults to local)
# Local: native meilisearch.exe.  Production: Meilisearch Cloud.
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=meilisearch-dev-key

# ── Error tracking — Sentry ──────────────────────────────────── OPTIONAL (Phase 9)
# https://sentry.io → Project → Settings → Client Keys (DSN). No-op when unset.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
# Release tag for Sentry (e.g. the git SHA); typically injected in CI/deploy.
APP_VERSION=

# =============================================================================
# PRODUCTION — set these as SECRETS in the Railway dashboard, not in a file:
#   NODE_ENV=production
#   DATABASE_URL          → Neon pooled connection string
#   REDIS_URL             → Upstash rediss:// URL
#   MEILISEARCH_URL / KEY → Meilisearch Cloud
#   CORS_ORIGIN           → https://yourdomain.com,https://admin.yourdomain.com
#   JWT_* · STRIPE_* · RESEND_* · R2_* · SENTRY_DSN · APP_VERSION
# Full step-by-step: docs/deployment.md
# =============================================================================

# =============================================================================
# Test environment — no .env.test needed
# Test variables are hardcoded in vitest.config.ts (ecommerce_test database).
# =============================================================================
