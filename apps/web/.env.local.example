# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
API_URL=http://localhost:4000/v1

# NextAuth (Auth.js v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_32_char_secret

# OAuth — Google (console.cloud.google.com → Credentials → OAuth 2.0 Client IDs)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# OAuth — GitHub (github.com/settings/developers → OAuth Apps)
# Authorized callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Stripe (publishable key only — secret key lives on the API)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
